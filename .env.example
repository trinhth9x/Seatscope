# Copy to ".env". Leave DATA_SOURCE=mock to preview with sample data.
# Set DATA_SOURCE=live once ANY connector below has credentials.
# In live mode, every connector with filled credentials runs and is merged.
DATA_SOURCE=mock
PORT=4000
# Auto-refresh runs daily at local 00:00 by default. Change the hour (0-23):
# REFRESH_DAILY_HOUR=0
# Or use a fixed interval instead (e.g. 168 = weekly). Set to 0 to disable.
# The UI Refresh button always fetches on demand regardless of these.
# REFRESH_INTERVAL_HOURS=168

# --- GitHub Copilot (FASTEST proof: exact per-seat last-used) ---
# Token = enterprise/org owner. Classic scopes: read:org, manage_billing:copilot (read-only).
# Multiple orgs in one enterprise: comma-separate them, e.g. GITHUB_ORG=org-a,org-b
GITHUB_ORG=
GITHUB_TOKEN=
# GITHUB_COPILOT_UNIT_COST=19   # override monthly price/seat if you know your contract

# --- GitHub Enterprise seats (dormant member detection) ---
# Activity = most recent of TWO signals:
#   (1) audit log (merges, approvals, pushes...)  -> needs scope read:audit_log
#   (2) contributions (commits/PRs/issues/reviews, incl. private) via GraphQL
# A member is only flagged dormant when BOTH are empty. So token needs:
#   read:org, read:audit_log
# GITHUB_ENTERPRISE_SEATS=true
# GITHUB_ENTERPRISE_UNIT_COST=21

# --- Microsoft 365 / Entra (Graph, app-only, read-only) ---
# Entra app Application permissions (admin-consented):
#   Organization.Read.All, User.Read.All, AuditLog.Read.All
# Note: signInActivity (last-used) requires Entra ID P1 on the tenant.
# Edit PRICE_MAP inside src/connectors/m365.js with your negotiated prices.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# --- Azure DevOps (user entitlements + last-access, read-only) ---
# PAT scope: Member Entitlement Management (Read) — vso.memberentitlementmanagement
# Prices default to Microsoft list (Basic $6, Basic+Test Plans $52); override per-license in the UI.
AZURE_DEVOPS_ORG=
AZURE_DEVOPS_TOKEN=

# --- Jira / Atlassian (org admin API, read-only) ---
# Uses the Atlassian Organizations API for per-product last_active.
# Get an org admin API key at admin.atlassian.com > Settings > API keys.
# JIRA_UNIT_COST optional (default 8); override per-license in the UI.
JIRA_ORG_ID=
JIRA_ADMIN_API_KEY=
# JIRA_UNIT_COST=8
